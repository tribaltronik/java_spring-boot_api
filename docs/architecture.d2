  shape: cloud
  style.fill: "#f0f0f0"
  
  User: {
    shape: person
    style.fill: "#e0e0e0"
  }

  Docker: {
    shape: rectangle
    style.fill: "#d0d0d0"
    
    PostgreSQL: {
      shape: database
      style.fill: "#c0c0c0"
    }

    Spring_Boot_API: {
      shape: rectangle
      style.fill: "#b0b0b0"
      
      Presentation_Layer: {
        shape: rectangle
        style.fill: "#a0a0a0"
      }
      Service_Layer: {
        shape: rectangle
        style.fill: "#909090"
      }
      Data_Access_Layer: {
        shape: rectangle
