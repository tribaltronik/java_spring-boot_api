      }
    }
  }
}

User -> Spring_Boot_API: "curl/browser" {
  style.stroke-dash: 2
}
Spring_Boot_API.Presentation_Layer -> Spring_Boot_API.Service_Layer
Spring_Boot_API.Service_Layer -> Spring_Boot_API.Data_Access_Layer
